<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0a0f">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header_gradient"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="48dp"
            android:paddingLeft="32dp"
            android:paddingRight="32dp"
            android:paddingBottom="28dp">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_logo"
                android:contentDescription="Logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Control Agent"
                android:textSize="26dp"
                android:textColor="#ffffff"
                android:textStyle="bold"
                android:layout_marginTop="14dp"
                android:letterSpacing="-0.02" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v1.0.0"
                android:textSize="13dp"
                android:textColor="#a5b4fc"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Controle remoto de dispositivos Android"
                android:textSize="12dp"
                android:textColor="#94a3b8"
                android:layout_marginTop="6dp" />

        </LinearLayout>

        <!-- Status Cards -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginTop="-12dp">

            <!-- Card: Server Status -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:gravity="center"
                            android:text="⚡"
                            android:textSize="17dp"
                            android:background="@drawable/bg_icon"
                            android:backgroundTint="#2d1b69" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Servidor"
                                android:textSize="14dp"
                                android:textColor="#e2e8f0"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/txtServer"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Desconectado"
                                android:textSize="12dp"
                                android:textColor="#64748b"
                                android:layout_marginTop="1dp" />

                        </LinearLayout>

                        <View
                            android:id="@+id/dotServer"
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/bg_dot"
                            android:backgroundTint="#ef4444" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/txtServerUrl"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Não configurado"
                        android:textSize="11dp"
                        android:textColor="#64748b"
                        android:layout_marginTop="12dp"
                        android:layout_marginStart="50dp"
                        android:fontFamily="monospace" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Accessibility Status -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clickable="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:gravity="center"
                            android:text="♿"
                            android:textSize="17dp"
                            android:background="@drawable/bg_icon"
                            android:backgroundTint="#1a2e1b" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Acessibilidade"
                                android:textSize="14dp"
                                android:textColor="#e2e8f0"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/txtAccessibility"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Desativada"
                                android:textSize="12dp"
                                android:textColor="#64748b"
                                android:layout_marginTop="1dp" />

                        </LinearLayout>

                        <View
                            android:id="@+id/dotAccessibility"
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/bg_dot"
                            android:backgroundTint="#ef4444" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Notification Status -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clickable="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:gravity="center"
                            android:text="🔔"
                            android:textSize="17dp"
                            android:background="@drawable/bg_icon"
                            android:backgroundTint="#1b2e2a" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Notificações"
                                android:textSize="14dp"
                                android:textColor="#e2e8f0"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/txtNotification"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Desativado"
                                android:textSize="12dp"
                                android:textColor="#64748b"
                                android:layout_marginTop="1dp" />

                        </LinearLayout>

                        <View
                            android:id="@+id/dotNotification"
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/bg_dot"
                            android:backgroundTint="#ef4444" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Device Info -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clickable="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:gravity="center"
                            android:text="📱"
                            android:textSize="17dp"
                            android:background="@drawable/bg_icon"
                            android:backgroundTint="#2d1b69" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Dispositivo"
                                android:textSize="14dp"
                                android:textColor="#e2e8f0"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/txtDeviceModel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="..."
                                android:textSize="13dp"
                                android:textColor="#94a3b8"
                                android:layout_marginTop="1dp" />

                        </LinearLayout>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/txtDeviceOS"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11dp"
                        android:textColor="#64748b"
                        android:layout_marginTop="8dp"
                        android:layout_marginStart="50dp"
                        android:fontFamily="monospace" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Buttons -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnScanQr"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:text="📷  Conectar por QR Code"
                style="@style/Widget.Custom.Button.Primary"
                android:textSize="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAccessibility"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:text="♿  Configurar Acessibilidade"
                style="@style/Widget.Custom.Button.Outlined" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNotification"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:text="🔔  Permitir Notificações"
                style="@style/Widget.Custom.Button.Outlined" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStop"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:text="⏹  Parar Serviço"
                style="@style/Widget.Custom.Button.Outlined"
                android:textColor="#ef4444"
                android:visibility="gone" />

            <!-- Footer -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Este app usa o Serviço de Acessibilidade para controlar remotamente. Mantenha o app rodando em segundo plano."
                android:textSize="11dp"
                android:textColor="#475569"
                android:layout_marginTop="24dp"
                android:lineSpacingExtra="4dp"
                android:gravity="center" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
